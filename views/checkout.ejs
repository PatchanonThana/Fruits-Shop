<%- include('partials/header', { title: 'Checkout' }) %>
<%- include('partials/navbar', { activePage: 'checkout' }) %>

<div class="checkout-page">
    <div class="checkout-container">

        <!-- ==================== LEFT: Shipping + Payment ==================== -->
        <div class="checkout-form-section">
            <h2 class="checkout-title">🛒 Checkout</h2>

            <!-- Error messages -->
            <div id="checkout-messages"></div>

            <form action="/checkout" method="POST" id="checkoutForm">

                <!-- SHIPPING INFO -->
                <div class="checkout-section-card">
                    <h3 class="checkout-section-title">📦 Shipping Information</h3>

                    <div class="form-group">
                        <label for="fullName">Full Name</label>
                        <input type="text" id="fullName" name="fullName" placeholder="John Doe" required>
                    </div>

                    <div class="form-group">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" name="phone" placeholder="0XX-XXX-XXXX" required>
                    </div>

                    <div class="form-group">
                        <label for="address">Address</label>
                        <textarea id="address" name="address" rows="3" placeholder="123 Fruit Street, Bangkok" required style="
                            width: 100%;
                            padding: 14px 18px;
                            background: rgba(255,255,255,0.5);
                            border: 2px solid rgba(76,175,80,0.15);
                            border-radius: 12px;
                            font-family: var(--font-body);
                            font-size: 0.95rem;
                            resize: vertical;
                            outline: none;
                            transition: all 0.3s ease;
                        "></textarea>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label for="city">City / Province</label>
                            <input type="text" id="city" name="city" placeholder="Bangkok" required>
                        </div>
                        <div class="form-group">
                            <label for="postalCode">Postal Code</label>
                            <input type="text" id="postalCode" name="postalCode" placeholder="10110" required maxlength="5">
                        </div>
                    </div>
                </div>

                <!-- PAYMENT METHOD -->
                <div class="checkout-section-card">
                    <h3 class="checkout-section-title">💳 Payment Method</h3>

                    <div class="payment-options">
                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="credit_card" required>
                            <div class="payment-option-content">
                                <span class="payment-icon">💳</span>
                                <div>
                                    <strong>Credit / Debit Card</strong>
                                    <small>Visa, Mastercard, JCB</small>
                                </div>
                            </div>
                        </label>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="bank_transfer">
                            <div class="payment-option-content">
                                <span class="payment-icon">🏦</span>
                                <div>
                                    <strong>Bank Transfer</strong>
                                    <small>Transfer to our bank account</small>
                                </div>
                            </div>
                        </label>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="promptpay">
                            <div class="payment-option-content">
                                <span class="payment-icon">📱</span>
                                <div>
                                    <strong>PromptPay / QR Code</strong>
                                    <small>Scan and pay instantly</small>
                                </div>
                            </div>
                        </label>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="cod">
                            <div class="payment-option-content">
                                <span class="payment-icon">🚚</span>
                                <div>
                                    <strong>Cash on Delivery</strong>
                                    <small>Pay when you receive</small>
                                </div>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Credit card fields (shown when credit card selected) -->
                <div class="checkout-section-card" id="cardDetails" style="display: none;">
                    <h3 class="checkout-section-title">💳 Card Details</h3>

                    <div class="form-group">
                        <label for="cardNumber">Card Number</label>
                        <input type="text" id="cardNumber" name="cardNumber" placeholder="1234 5678 9012 3456" maxlength="19">
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                        <div class="form-group">
                            <label for="expiry">Expiry Date</label>
                            <input type="text" id="expiry" name="expiry" placeholder="MM/YY" maxlength="5">
                        </div>
                        <div class="form-group">
                            <label for="cvv">CVV</label>
                            <input type="text" id="cvv" name="cvv" placeholder="123" maxlength="3">
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-place-order">
                    🍉 Place Order — ฿<%= total.toFixed(2) %>
                </button>
            </form>
        </div>

        <!-- ==================== RIGHT: Order Summary ==================== -->
        <div class="checkout-summary">
            <div class="checkout-summary-card">
                <h3>📋 Order Summary</h3>

                <div class="checkout-items-list">
                    <% cartItems.forEach(function(item) { %>
                        <div class="checkout-item">
                            <div class="checkout-item-image">
                                <img src="/images/<%= item.image_path %>" alt="<%= item.name %>">
                            </div>
                            <div class="checkout-item-info">
                                <h4><%= item.name %></h4>
                                <span class="checkout-item-qty">× <%= item.qty %></span>
                            </div>
                            <%
                                const itemTotal = item.price * item.qty;
                                const itemTotalStr = '฿' + itemTotal.toFixed(2);
                            %>
                            <div class="checkout-item-price"><%- itemTotalStr %></div>
                        </div>
                    <% }); %>
                </div>

                <div class="checkout-summary-divider"></div>

                <div class="checkout-summary-row">
                    <span>Subtotal</span>
                    <span>฿<%= subtotal.toFixed(2) %></span>
                </div>
                <div class="checkout-summary-row">
                    <span>Shipping</span>
                    <span style="color: var(--primary-dark); font-weight: 600;">
                        <% if (shipping === 0) { %>FREE 🎉<% } else { %>฿<%= shipping.toFixed(2) %><% } %>
                    </span>
                </div>
                <div class="checkout-summary-row total">
                    <span>Total</span>
                    <span>฿<%= total.toFixed(2) %></span>
                </div>

                <a href="/cart-page" class="btn-back-to-cart">← Back to Cart</a>
            </div>
        </div>

    </div>
</div>

<script>
    // Show/hide credit card fields
    document.querySelectorAll('input[name="paymentMethod"]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            const cardDetails = document.getElementById('cardDetails');
            if (this.value === 'credit_card') {
                cardDetails.style.display = 'block';
                cardDetails.querySelector('#cardNumber').required = true;
                cardDetails.querySelector('#expiry').required = true;
                cardDetails.querySelector('#cvv').required = true;
            } else {
                cardDetails.style.display = 'none';
                cardDetails.querySelector('#cardNumber').required = false;
                cardDetails.querySelector('#expiry').required = false;
                cardDetails.querySelector('#cvv').required = false;
            }
        });
    });

    // Format card number with spaces
    document.getElementById('cardNumber').addEventListener('input', function(e) {
        let value = e.target.value.replace(/\s/g, '').replace(/\D/g, '');
        let formatted = value.match(/.{1,4}/g);
        e.target.value = formatted ? formatted.join(' ') : '';
    });

    // Format expiry MM/YY
    document.getElementById('expiry').addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length >= 2) {
            value = value.substring(0, 2) + '/' + value.substring(2);
        }
        e.target.value = value;
    });

    // Error from URL
    const params = new URLSearchParams(window.location.search);
    if (params.get('error') === '1') {
        document.getElementById('checkout-messages').innerHTML =
            '<div class="auth-error">⚠️ Something went wrong. Please try again.</div>';
    }
</script>

<script src="/js/main.js"></script>
</body>
</html>