<%- include('partials/header', { title: 'Order Confirmed!' }) %>
<%- include('partials/navbar', { activePage: 'checkout' }) %>

<div class="auth-page">
    <div class="auth-container" style="text-align: center; padding: 60px 40px;">

        <!-- Success Animation -->
        <div class="success-checkmark">
            <div class="success-icon">✅</div>
        </div>

        <h2 class="auth-title" style="margin-top: 20px;">Order Confirmed!</h2>
        <p class="auth-subtitle" style="font-size: 1.1rem;">
            🎉 Thank you for your purchase!
        </p>

        <div class="success-details">
            <div class="success-detail-item">
                <span>📦</span>
                <p>Your fresh fruits are being prepared and will be delivered soon.</p>
            </div>
            <div class="success-detail-item">
                <span>📧</span>
                <p>A confirmation email has been sent to your registered email.</p>
            </div>
            <div class="success-detail-item">
                <span>🚚</span>
                <p>Estimated delivery: 1-3 business days</p>
            </div>
        </div>

        <div style="margin-top: 30px; display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
            <a href="/shop-page" class="btn-auth" style="display: inline-block; width: auto; padding: 14px 30px;">
                🍉 Continue Shopping
            </a>
            <a href="/categories-page" class="btn-show-more" style="margin-top: 0;">
                Browse Categories →
            </a>
        </div>
    </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>