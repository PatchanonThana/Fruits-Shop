<%- include('partials/header', { title: 'Home' }) %>
<%- include('partials/navbar', { activePage: 'home' }) %>

<!-- ==================== HERO BANNER ==================== -->
<section class="hero">
    <img src="/images/main_banner_bg.png" alt="Fresh Fruits Banner" class="hero-banner">
    <div class="hero-overlay"></div>

    <div class="hero-float">🍊</div>
    <div class="hero-float">🥭</div>
    <div class="hero-float">🍓</div>
    <div class="hero-float">🍍</div>

    <div class="hero-content">
        <h1>Fruit Shop</h1>
        <p>Fruit flesh, the real taste of nature.</p>
        <a href="/categories-page" class="btn-catalog">🛒 Browse Catalog</a>
    </div>
</section>

<!-- ==================== BESTSELLERS ==================== -->
<section class="section" id="bestsellers">
    <h2 class="section-title animate-in">Bestsellers</h2>

    <div class="bestsellers-grid animate-in">
        <% bestSellers.forEach(function(fruit, index) { %>
            <% if (fruit) { %>
            <%
                const cardBg = 'background: linear-gradient(135deg, ' + fruit.cardColor + '33, ' + fruit.cardColor + '15)';
                const fruitId = fruit.fruit_id;

                var badgeHTML = '';
                if (index === 0) {
                    badgeHTML = '<span class="product-badge">🔥 HOT</span>';
                } else if (index === 1) {
                    badgeHTML = '<span class="product-badge" style="background:linear-gradient(135deg,#FFD93D,#F39C12)">⭐ POPULAR</span>';
                }
            %>
            <div class="product-card animate-child">
                <div class="product-card-image" style="<%- cardBg %>">
                    <%- badgeHTML %>
                    <div class="product-wishlist">🤍</div>
                    <img src="/images/<%= fruit.image_path %>" alt="<%= fruit.name %>">
                </div>
                <div class="product-card-info">
                    <h4><%= fruit.name %></h4>
                    <p class="product-desc"><%= fruit.description %></p>
                    <div class="product-card-bottom">
                        <span class="product-price">฿<%= fruit.price %></span>
                        <button class="btn-add-cart" data-fruit-id="<%- fruitId %>" title="Add to cart">
                            <img src="/images/cart.svg" alt="Add to cart">
                        </button>
                    </div>
                </div>
            </div>
            <% } %>
        <% }); %>
    </div>

    <div style="text-align: right;">
        <a href="/categories-page" class="btn-show-more">Show more →</a>
    </div>
</section>

<!-- ==================== MAKING A JUICE ==================== -->
<section class="juice-section" id="juice">
    <h2 class="section-title animate-in">Making a Juice!</h2>

    <div class="juice-grid animate-in">
        <div class="juice-card juice-card-left">
            <div class="juice-card-content">
                <h3>Mixed Berry Blast 🫐</h3>
                <p>
                    Blend together fresh strawberries, blueberries, and raspberries for a
                    refreshing antioxidant-packed smoothie. Add a splash of honey and yogurt
                    for the perfect creamy texture. Nature's perfect energy booster!
                </p>
            </div>
            <div class="juice-card-image">
                <img src="/images/mixberry.png" alt="Mixed Berry Drink">
            </div>
        </div>

        <div class="juice-card juice-card-right">
            <div class="juice-card-content">
                <h3>Avocado Smoothie 🥑</h3>
                <p>
                    Creamy, dreamy avocado blended with fresh milk and a touch of sweetness.
                    Rich in healthy fats and vitamins, this smoothie is both delicious and
                    nutritious. The ultimate guilt-free treat!
                </p>
            </div>
            <div class="juice-card-image">
                <img src="/images/avocado.png" alt="Avocado Smoothie">
            </div>
        </div>
    </div>

    <div class="juice-showcase animate-in">
        <div class="juice-mini-card">
            <img src="/images/rainbowsmoothie.png" alt="Rainbow Smoothie">
            <span>Rainbow Smoothie</span>
        </div>
        <div class="juice-mini-card">
            <img src="/images/strawberryjuice.png" alt="Strawberry Juice">
            <span>Strawberry Juice</span>
        </div>
        <div class="juice-mini-card">
            <img src="/images/coconutwater.png" alt="Coconut Water">
            <span>Coconut Water</span>
        </div>
        <div class="juice-mini-card">
            <img src="/images/grapejuice.png" alt="Grape Juice">
            <span>Grape Juice</span>
        </div>
        <div class="juice-mini-card">
            <img src="/images/pineapplejuice.png" alt="Pineapple Juice">
            <span>Pineapple Juice</span>
        </div>
    </div>
</section>

<!-- ==================== CATEGORIES ==================== -->
<section class="categories-section" id="categories">
    <h2 class="section-title animate-in">Categories</h2>

    <div class="categories-list animate-in">
        <% categories.forEach(function(cat, index) { %>
            <%
                const slugPrefix = cat.slug.split('_');
                const barClass = 'category-bar cat-' + slugPrefix + ' animate-child';
            %>
            <a href="/categories-page?cat=<%= cat.slug %>" class="<%- barClass %>">
                <div class="category-bar-left">
                    <h3><%= cat.emoji %> <%= cat.name %></h3>
                    <p><%= cat.desc %></p>
                </div>
                <div class="category-bar-right">
                    <img src="/images/<%= cat.image_path %>" alt="<%= cat.name %>">
                </div>
            </a>
        <% }); %>
    </div>
</section>

<!-- ==================== POPULAR TREATS PREVIEW ==================== -->
<section class="section" id="treats">
    <h2 class="section-title animate-in">Popular Treats 🍨</h2>

    <div class="treats-scroll animate-in">
        <%
            const treats = [
                { name: 'Tanghulu', image: 'tanghulu.png', price: 40, gradient: 'linear-gradient(135deg, #FFECD2, #FCB69F)' },
                { name: 'Shave Ice', image: 'shaveice.png', price: 35, gradient: 'linear-gradient(135deg, #A1C4FD, #C2E9FB)' },
                { name: 'Ice Cream', image: 'icecream.png', price: 50, gradient: 'linear-gradient(135deg, #FFDEE9, #B5FFFC)' },
                { name: 'Crepe', image: 'crepe.png', price: 55, gradient: 'linear-gradient(135deg, #FFF1EB, #ACE0F9)' },
                { name: 'Pudding', image: 'pudding.png', price: 40, gradient: 'linear-gradient(135deg, #E8D5B7, #F5E6CC)' },
                { name: 'Yogurt', image: 'yogurt.png', price: 45, gradient: 'linear-gradient(135deg, #FBC2EB, #A6C1EE)' },
                { name: 'Jelly', image: 'jelly.png', price: 30, gradient: 'linear-gradient(135deg, #D4FC79, #96E6A1)' }
            ];
        %>
        <% treats.forEach(function(treat) { %>
            <%
                const treatBg = 'background: ' + treat.gradient;
            %>
            <div class="treat-card">
                <div class="treat-image" style="<%- treatBg %>">
                    <img src="/images/<%= treat.image %>" alt="<%= treat.name %>">
                </div>
                <h4><%= treat.name %></h4>
                <span class="product-price">฿<%= treat.price %></span>
            </div>
        <% }); %>
    </div>
</section>

<%- include('partials/footer') %>