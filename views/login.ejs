<%- include('partials/header', { title: 'Login' }) %>
<%- include('partials/navbar', { activePage: 'login' }) %>

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-logo">🍉</div>
        <h2 class="auth-title">Welcome Back!</h2>
        <p class="auth-subtitle">Sign in to your Fruit Shop account</p>

        <!-- ==================== ERROR MESSAGES ==================== -->
        <div id="auth-messages"></div>

        <form action="/login" method="POST">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required>
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                <label style="display: flex; align-items: center; gap: 6px; font-size: 0.85rem; cursor: pointer;">
                    <input type="checkbox" name="remember" style="accent-color: var(--primary);">
                    Remember me
                </label>
                <a href="#" style="font-size: 0.85rem; color: var(--primary-dark); font-weight: 600;">Forgot password?</a>
            </div>

            <button type="submit" class="btn-auth">🍉 Sign In</button>
        </form>

        <p class="auth-footer">
            Don't have an account? <a href="/register-page">Sign Up</a>
        </p>
    </div>
</div>

<script>
    // ==========================================
    // Read URL params and show messages
    // ==========================================
    document.addEventListener('DOMContentLoaded', function() {
        const params = new URLSearchParams(window.location.search);
        const msgBox = document.getElementById('auth-messages');

        if (params.get('NoUser') === '1') {
            msgBox.innerHTML = '<div class="auth-error">⚠️ Invalid email or password. Please try again.</div>';
        }

        if (params.get('notLoginYet') === '1') {
            msgBox.innerHTML = '<div class="auth-warning">🔐 Please login first to access the shop.</div>';
        }

        if (params.get('success') === '1') {
            msgBox.innerHTML = '<div class="auth-success">✅ Account created successfully! Please login.</div>';
        }

        if (params.get('loggedOut') === '1') {
            msgBox.innerHTML = '<div class="auth-success">👋 You have been logged out successfully.</div>';
        }
    });
</script>

<script src="/js/main.js"></script>
</body>
</html>